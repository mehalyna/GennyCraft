{
  "servers": {
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp"
    },
    "figma-local": {
      "command": "npx",
      "args": [
        "-y",
        "figma-developer-mcp",
        "--figma-api-key=${input:figma_api_key}",
        "--stdio"
      ]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp"
      ]
    },
    "gennycraft": {
      "type": "stdio",
      "command": "node",
      "args": ["gennycraft-mcp-wrapper.js"]
    }
  },
  "inputs": [
    {
      "id": "figma_api_key",
      "type": "promptString",
      "description": "Figma API Key (Settings → Account → Personal access tokens)",
      "password": true
    }
  ]
}